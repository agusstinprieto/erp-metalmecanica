{
  "expo": {
    "name": "McVill ERP",
    "slug": "mcvill-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "mcvill",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#030712"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mcvill.erp",
      "infoPlist": {
        "NSCameraUsageDescription": "Escaneo de códigos QR en viajeros y captura de fotos para no-conformidades",
        "NSPhotoLibraryUsageDescription": "Seleccionar fotos para adjuntar a inspecciones de calidad"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#030712"
      },
      "package": "com.mcvill.erp",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir el acceso a la cámara para escanear viajeros y capturar fotos de inspección."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acceso a fotos para adjuntar en inspecciones de calidad."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
